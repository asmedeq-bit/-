async function init(){
  showLoading(true);
  try {
    const { data, error } = await sb.from('categories').select('*').order('display_order').order('name');
    if(error) throw error;
    S.categories = data || [];
    buildSidebarNav();
    if(!S.categories.length){
      showLoading(false);
      document.getElementById('empty-categories').style.display = '';
      document.getElementById('dash-content').style.display = 'none';
      return;
    }
    document.getElementById('empty-categories').style.display = 'none';
    document.getElementById('dash-content').style.display = '';
    await loadDashboard();
  } catch(e){
    showLoading(false);
    toast('เชื่อมต่อ Supabase ไม่ได้: '+e.message,'error');
  }
}

function buildSidebarNav(){
  document.getElementById('sheet-nav-list').innerHTML = S.categories.map((cat,i)=>`
    <div class="nav-item" id="nav-sheet-${i}" onclick="showCategory(${cat.id},${i})">
      <span class="nav-icon"><i class="fas fa-table"></i></span>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(cat.name)}">${escHtml(cat.name)}</span>
    </div>`).join('');
}
function setActiveNav(id){ document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); const el=document.getElementById(id); if(el)el.classList.add('active'); }

