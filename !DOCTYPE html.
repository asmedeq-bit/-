function renderDonut(sm){
  const mainEntries = Object.entries(sm).filter(([k])=>k.trim()).sort((a,b)=>b[1]-a[1]);
  const total = mainEntries.reduce((s,[,v])=>s+v,0);
  const svg = document.getElementById('donut-svg');
  if(!total){ svg.innerHTML=''; document.getElementById('donut-legend').innerHTML='<div style="color:var(--text-muted);font-size:12px">ยังไม่มีข้อมูล</div>'; return; }
  const [cx,cy,r,inn]=[70,70,55,35];
  let start=-Math.PI/2, paths='';
  mainEntries.forEach(([label,val],i)=>{
    const angle=val/total*Math.PI*2, end=start+angle;
    const[x1,y1,x2,y2]=[cx+r*Math.cos(start),cy+r*Math.sin(start),cx+r*Math.cos(end),cy+r*Math.sin(end)];
    const[xi1,yi1,xi2,yi2]=[cx+inn*Math.cos(start),cy+inn*Math.sin(start),cx+inn*Math.cos(end),cy+inn*Math.sin(end)];
    const lg=angle>Math.PI?1:0, c=COLORS[i%COLORS.length];
    const safeLabel=label.replace(/'/g,"\\'");
    paths+=`<path class="donut-slice" d="M${xi1},${yi1} L${x1},${y1} A${r},${r} 0 ${lg} 1 ${x2},${y2} L${xi2},${yi2} A${inn},${inn} 0 ${lg} 0 ${xi1},${yi1}" fill="${c}" opacity=".9" onclick="openStatusModal('${safeLabel}','${c}')" title="${escHtml(label)}: ${val} รายการ"/>`;
    start=end;
  });
  svg.innerHTML=paths+`<text x="70" y="70" text-anchor="middle" dominant-baseline="middle" font-size="20" font-weight="700" fill="#1e293b">${total.toLocaleString()}</text><text x="70" y="86" text-anchor="middle" font-size="10" fill="#64748b">รายการ</text>`;
  document.getElementById('donut-legend').innerHTML = mainEntries.slice(0,8).map(([label,val],i)=>`
    <div class="legend-item" onclick="openStatusModal('${label.replace(/'/g,"\\'")}','${COLORS[i%COLORS.length]}')" title="คลิกดูรายการสถานะ: ${escHtml(label)}">
      <div class="legend-dot" style="background:${COLORS[i%COLORS.length]}"></div>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtml(label)}</span>
      <strong>${val}</strong>
      <i class="fas fa-chevron-right" style="font-size:10px;color:var(--text-muted);margin-left:4px"></i>
    </div>`).join('');
}

// =============================================
// CATEGORY (sheet) VIEW
// =============================================
function showCategoryById(catId){
  const idx = S.categories.findIndex(c => c.id === catId);
  if(idx >= 0) showCategory(catId, idx);
}

async function showCategory(catId, navIdx){
  const cat = S.categories.find(c => c.id === catId);
  if(!cat) return;
  S.currentCat = cat; S.currentNavIdx = navIdx;
  document.getElementById('view-dashboard').style.display='none';
  document.getElementById('view-table').style.display='';
  document.getElementById('btn-add').style.display='';
  document.getElementById('page-title').textContent = cat.name;
  document.getElementById('page-subtitle').textContent = 'รายการพัสดุ: ' + cat.name;
  document.getElementById('table-title').textContent = cat.name;
  setActiveNav('nav-sheet-' + navIdx);
  if(S.allItems[catId]) renderTable(cat);
  else await loadCategoryItems(cat);
}

async function loadCategoryItems(cat){
  showLoading(true);
  try {
    const { data, error } = await sb.from('items').select('*').eq('category_id', cat.id).order('row_index').order('id');
    if(error) throw error;
    S.allItems[cat.id] = data || [];
    showLoading(false);
    renderTable(cat);
  } catch(e){
    showLoading(false);
    toast('โหลดข้อมูลไม่สำเร็จ: '+e.message,'error');
  }
}

function renderTable(cat){
  const headers = cat.headers || [];
  if(!headers.length){
    document.getElementById('table-body').innerHTML = '<tr><td colspan="999" style="text-align:center;padding:40px;color:var(--text-muted)">ยังไม่ได้ตั้งค่าคอลัมน์ของประเภทนี้</td></tr>';
    document.getElementById('table-head').innerHTML = '';
    return;
  }
  S.currentPage = 1; S.sortCol = null;
  buildFilters(cat);
  applyFilters();
}

function buildFilters(cat){
  const items = S.allItems[cat.id] || [];
  const headers = cat.headers || [];
  const sk = headers.findIndex(isStatusCol);
  const dk = headers.findIndex(isDeptCol);
  const statusSet = new Set(), deptSet = new Set();
  items.forEach(it => {
    if(sk >= 0){ const v = normalizeStatus(it.data?.[headers[sk]]); if(v) statusSet.add(v); }
    if(dk >= 0){ const v = String(it.data?.[headers[dk]]||'').trim(); if(v) deptSet.add(v); }
  });
  document.getElementById('status-filter').innerHTML = '<option value="">-- ทุกสถานะ --</option>' + [...statusSet].sort().map(s=>`<option>${escHtml(s)}</option>`).join('');
  document.getElementById('dept-filter').innerHTML = '<option value="">-- ทุกแผนก --</option>' + [...deptSet].sort().map(s=>`<option>${escHtml(s)}</option>`).join('');
}

function applyFilters(){
  const cat = S.currentCat; if(!cat) return;
  const items = S.allItems[cat.id] || [];
  const headers = cat.headers || [];
  const rawQ = document.getElementById('search-input').value;
  const q = rawQ.toLowerCase();
  document.getElementById('btn-clear-search').style.display = q ? '' : 'none';
  const st = document.getElementById('status-filter').value;
  const dp = document.getElementById('dept-filter').value;
  const sk = headers.findIndex(isStatusCol);
  const dk = headers.findIndex(isDeptCol);

  S.filteredRows = items.filter(it => {
    if(st && sk >= 0 && normalizeStatus(it.data?.[headers[sk]]) !== st) return false;
    if(dp && dk >= 0 && String(it.data?.[headers[dk]]||'').trim() !== dp) return false;
    if(q){
      const arr = rowToArr(it, headers);
      return arr.some(v => matchSearch(String(v||'').toLowerCase(), q));
    }
    return true;
  });

  if(S.sortCol !== null){
    S.filteredRows.sort((a,b)=>{
      const av = String(a.data?.[headers[S.sortCol]] || '');
      const bv = String(b.data?.[headers[S.sortCol]] || '');
      return S.sortDir==='asc' ? av.localeCompare(bv,'th') : bv.localeCompare(av,'th');
    });
  }
  S.currentPage = 1;
  renderTableBody(headers, rawQ);
}

function changePS(v){ S.pageSize=parseInt(v); S.currentPage=1; renderTableBody(S.currentCat.headers, document.getElementById('search-input').value); }

function renderTableBody(headers, rawQ){
  const rows = S.filteredRows, total = rows.length;
  const pages = Math.max(1, Math.ceil(total/S.pageSize));
  const start = (S.currentPage-1) * S.pageSize;
  const pageRows = rows.slice(start, start+S.pageSize);
  const sk = headers.findIndex(isStatusCol);
  const q = rawQ ? rawQ.toLowerCase() : '';

  document.getElementById('table-head').innerHTML = `<tr>
    <th style="width:44px;min-width:44px">#</th>
    ${headers.map((h,i)=>{
      const icon = S.sortCol===i ? (S.sortDir==='asc'?'fa-sort-up':'fa-sort-down') : 'fa-sort';
      return `<th class="${S.sortCol===i?'sorted':''}" onclick="sortTable(${i})" style="min-width:110px">${escHtml(h)} <i class="fas ${icon} si"></i></th>`;
    }).join('')}
    <th style="width:90px;min-width:90px">จัดการ</th>
  </tr>`;

  document.getElementById('table-body').innerHTML = pageRows.length ? pageRows.map((it,ri)=>{
    return `<tr>
      <td style="color:var(--text-muted);font-size:11px;font-weight:600;background:#f8fafc">${start+ri+1}</td>
      ${headers.map((h,ci)=>{
        const val = (it.data && it.data[h] !== undefined && it.data[h] !== null) ? String(it.data[h]) : '';
        if(ci === sk){ const nv = normalizeStatus(val); if(nv) return `<td><span class="status-badge ${getStCls(nv)}">${escHtml(nv)}</span></td>`; return `<td></td>`; }
        return `<td title="${escHtml(val)}">${q ? highlightMatch(val, rawQ, S.searchMode) : escHtml(val)}</td>`;
      }).join('')}
      <td>
        <div class="td-actions">
          <button class="btn btn-outline btn-sm btn-icon" onclick="openEditModal(${it.id})" title="แก้ไข"><i class="fas fa-edit"></i></button>
          <button class="btn btn-danger btn-sm btn-icon" onclick="openDelModal(${it.id})" title="ลบ"><i class="fas fa-trash"></i></button>
        </div>
      </td>
    </tr>`;
  }).join('') : `<tr><td colspan="999" style="text-align:center;padding:52px;color:var(--text-muted)"><i class="fas fa-inbox" style="font-size:36px;display:block;margin-bottom:12px;opacity:.35"></i>ไม่พบข้อมูล</td></tr>`;

  document.getElementById('record-count').textContent = `${Math.min(start+1,total)}–${Math.min(start+S.pageSize,total)} จาก ${total} รายการ`;
  document.getElementById('page-info').textContent = `หน้า ${S.currentPage}/${pages} (${total} รายการ)`;
  renderPagination(pages);
}

function getStCls(v){
  const s = v.trim();
  if(s==='ใช้ราชการได้') return 'st-good';
  if(['รอจำหน่าย','ทำเรื่องจำหน่าย','ทำจำหน่าย','ทำเรื่องจำหน่ายใหม่รอใบ decom','รอจำหน่ายรอใบ decom','ระหว่างทำเรื่องจำหน่าย'].includes(s)) return 'st-wait';
  if(s==='จำหน่าย'||s==='จำหน่ายแล้ว') return 'st-done';
  if(s==='ชำรุด') return 'st-broken';
  if(s==='S') return 'st-s';
  return 'st-other';
}

function renderPagination(pages){
  const cp = S.currentPage;
  let range = pages<=7 ? [...Array(pages)].map((_,i)=>i+1) :
              cp<=4 ? [1,2,3,4,5,'…',pages] :
              cp>=pages-3 ? [1,'…',pages-4,pages-3,pages-2,pages-1,pages] :
              [1,'…',cp-1,cp,cp+1,'…',pages];
  document.getElementById('page-btns').innerHTML =
    `<div class="page-btn ${cp<=1?'dis':''}" onclick="goPage(${cp-1})"><i class="fas fa-chevron-left"></i></div>` +
    range.map(p=>p==='…' ? `<div class="page-btn" style="cursor:default;border:none">…</div>` : `<div class="page-btn ${p===cp?'active':''}" onclick="goPage(${p})">${p}</div>`).join('') +
    `<div class="page-btn ${cp>=pages?'dis':''}" onclick="goPage(${cp+1})"><i class="fas fa-chevron-right"></i></div>`;
}

function goPage(p){
  const pages = Math.ceil(S.filteredRows.length/S.pageSize);
  if(p<1||p>pages) return;
  S.currentPage = p; renderTableBody(S.currentCat.headers, document.getElementById('search-input').value);
  document.getElementById('table-wrap').scrollTop = 0;
}

function sortTable(ci){
  if(S.sortCol === ci) S.sortDir = S.sortDir==='asc'?'desc':'asc';
  else { S.sortCol = ci; S.sortDir = 'asc'; }
  applyFilters();
}

// =============================================
// FORM
// =============================================
function buildForm(headers, rowArr){
  document.getElementById('modal-form').innerHTML = headers.map((h,i)=>{
    const val = rowArr && rowArr[i] !== undefined ? String(rowArr[i]) : '';
    const isDate = DATE_FIELDS.some(d => h.includes(d.trim()));
    const isNum = NUM_FIELDS.some(d => h.trim() === d.trim());
    const isTxt = TEXT_ONLY_FIELDS.some(d => h.trim() === d.trim());
    const ddOpts = !isTxt && (STATIC_DROPDOWNS[h.trim()] || STATIC_DROPDOWNS[h]) || null;
    const isFirst2 = i < 2;
    let field = '';
    if(isDate) field = `<input type="date" class="plain-input" id="f${i}" value="${escHtml(val)}">`;
    else if(isNum) field = `<input type="number" class="plain-input" id="f${i}" value="${escHtml(val)}" step="any">`;
    else if(isTxt) field = `<input type="text" class="plain-input" id="f${i}" value="${escHtml(val)}" placeholder="${escHtml(h)}">`;
    else if(ddOpts && ddOpts.length) field = buildCombo(i, val, ddOpts);
    else field = `<input type="text" class="plain-input" id="f${i}" value="${escHtml(val)}" placeholder="${escHtml(h)}">`;
    const hasDD = ddOpts && ddOpts.length && !isDate && !isNum && !isTxt;
    return `<div class="form-group ${isFirst2?'full':''}">
      <label class="form-label">${escHtml(h)}${hasDD?'<span class="badge-dd"><i class="fas fa-list" style="font-size:9px"></i> dropdown</span>':''}</label>
      ${field}
    </div>`;
  }).join('');
}

function buildCombo(idx, cur, options){
  return `<div class="combo-wrap" id="cw${idx}">
    <input type="text" id="f${idx}" value="${escHtml(cur)}" placeholder="พิมพ์หรือเลือก..." autocomplete="off"
      oninput="filterDD(${idx})" onfocus="openDD(${idx})" onkeydown="keyDD(event,${idx})">
    <i class="fas fa-chevron-down dd-arrow"></i>
    <div class="dd-list" id="dl${idx}">
      ${options.map(o=>`<div class="dd-item" data-val="${escHtml(o)}" onmousedown="selectDD(${idx},'${esc(o)}')">${escHtml(o)}</div>`).join('')}
    </div>
  </div>`;
}

function openDD(idx){ closeAllDD(); const l=document.getElementById('dl'+idx), w=document.getElementById('cw'+idx); if(l){ l.classList.add('open'); S.activeDD=w; filterDD(idx); }}
function closeAllDD(){ document.querySelectorAll('.dd-list.open').forEach(el=>el.classList.remove('open')); S.activeDD=null; }
function filterDD(idx){
  const inp=document.getElementById('f'+idx), l=document.getElementById('dl'+idx); if(!l) return;
  const q=(inp.value||'').toLowerCase(); let vis=0;
  l.querySelectorAll('.dd-item').forEach(it=>{ const m=!q||it.dataset.val.toLowerCase().includes(q); it.style.display=m?'':'none'; if(m)vis++; });
  let em=l.querySelector('.dd-empty');
  if(!vis){ if(!em){ em=document.createElement('div'); em.className='dd-empty'; em.textContent='ไม่พบ (พิมพ์เพิ่มเองได้)'; l.appendChild(em); }} else if(em) em.remove();
  l.classList.add('open'); S.activeDD=document.getElementById('cw'+idx);
}
function selectDD(idx,val){ document.getElementById('f'+idx).value=val; closeAllDD(); }
function keyDD(e,idx){
  const l=document.getElementById('dl'+idx); if(!l) return;
  const items=[...l.querySelectorAll('.dd-item:not([style*="none"])')];
  const cur=l.querySelector('.dd-item.hl');
  if(e.key==='ArrowDown'){ e.preventDefault(); const n=cur?(items[items.indexOf(cur)+1]||items[0]):items[0]; if(cur)cur.classList.remove('hl'); if(n){n.classList.add('hl'); n.scrollIntoView({block:'nearest'});} }
  else if(e.key==='ArrowUp'){ e.preventDefault(); const p=cur?(items[items.indexOf(cur)-1]||items[items.length-1]):items[items.length-1]; if(cur)cur.classList.remove('hl'); if(p){p.classList.add('hl'); p.scrollIntoView({block:'nearest'});} }
  else if(e.key==='Enter'){ e.preventDefault(); if(cur)selectDD(idx,cur.dataset.val); else closeAllDD(); }
  else if(e.key==='Escape') closeAllDD();
}

// =============================================
// MODAL — EDIT/ADD
// =============================================
function openEditModal(itemId){
  const cat = S.currentCat || S.categories.find(c => (S.allItems[c.id]||[]).some(it => it.id === itemId));
  if(!cat) return;
  if(!S.currentCat || S.currentCat.id !== cat.id) S.currentCat = cat;
  const item = (S.allItems[cat.id]||[]).find(it => it.id === itemId);
  if(!item) return;
  S.editItemId = itemId;
  document.getElementById('modal-title').innerHTML = `<i class="fas fa-edit" style="color:var(--primary)"></i> แก้ไขรายการ <span style="font-size:12px;color:var(--text-muted);font-weight:400">— ${escHtml(cat.name)}</span>`;
  buildForm(cat.headers, rowToArr(item, cat.headers));
  document.getElementById('modal-overlay').classList.add('show');
}

function openAddModal(){
  if(!S.currentCat) return;
  S.editItemId = null;
  document.getElementById('modal-title').innerHTML = '<i class="fas fa-plus-circle" style="color:var(--success)"></i> เพิ่มรายการใหม่';
  buildForm(S.currentCat.headers, null);
  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal(){ document.getElementById('modal-overlay').classList.remove('show'); closeAllDD(); }

async function saveRow(){
  const cat = S.currentCat; if(!cat) return;
  const headers = cat.headers || [];
  const arr = headers.map((_,i)=> document.getElementById('f'+i).value);
  const obj = arrToObj(arr, headers);
  const sk = headers.findIndex(isStatusCol);
  const dk = headers.findIndex(isDeptCol);
  const status = sk>=0 ? normalizeStatus(arr[sk]) : null;
  const dept = dk>=0 ? String(arr[dk]||'').trim() || null : null;

  showLoading(true);
  try {
    if(S.editItemId !== null){
      const { error } = await sb.from('items').update({ data: obj, status, department: dept }).eq('id', S.editItemId);
      if(error) throw error;
      toast('บันทึกสำเร็จ','success');
    } else {
      const items = S.allItems[cat.id]||[];
      const nextRow = items.length ? Math.max(...items.map(i=>i.row_index||0))+1 : 0;
      const { error } = await sb.from('items').insert({ category_id: cat.id, data: obj, status, department: dept, row_index: nextRow });
      if(error) throw error;
      toast('เพิ่มรายการสำเร็จ','success');
    }
    closeModal();
    await invalidate();
    if(S._smReopen){ const fn = S._smReopen; S._smReopen = null; setTimeout(fn, 250); }
  } catch(e){
    toast('ผิดพลาด: '+e.message,'error');
  } finally { showLoading(false); }
}

function openDelModal(itemId){
  const cat = S.currentCat || S.categories.find(c => (S.allItems[c.id]||[]).some(it => it.id === itemId));
  const item = cat ? (S.allItems[cat.id]||[]).find(it=>it.id===itemId) : null;
  if(!item || !cat) return;
  S.delItemId = itemId;
  S._delCatId = cat.id;
  const firstKey = (cat.headers && cat.headers[0]) || '';
  document.getElementById('del-info').innerHTML = `<strong>${escHtml(firstKey)}:</strong> ${escHtml(String(item.data?.[firstKey]||'-'))}`;
  document.getElementById('del-overlay').classList.add('show');
}
function closeDelModal(){ document.getElementById('del-overlay').classList.remove('show'); }

async function confirmDelete(){
  showLoading(true);
  try {
    const { error } = await sb.from('items').delete().eq('id', S.delItemId);
    if(error) throw error;
    closeDelModal();
    toast('ลบสำเร็จ','success');
    await invalidate();
  } catch(e){
    toast('ผิดพลาด: '+e.message,'error');
  } finally { showLoading(false); }
}

async function invalidate(){
  if(S.currentCat){ delete S.allItems[S.currentCat.id]; }
  S.dashStats = null;
  if(S.currentCat) await loadCategoryItems(S.currentCat);
  else await loadDashboard();
}

// =============================================
// EXPORT
// =============================================
function exportData(type){
  const cat = S.currentCat; if(!cat) return;
  const headers = cat.headers || [];
  const rows = S.filteredRows.map(it => rowToArr(it, headers));
  const name = cat.name;
  if(type==='csv'){
    let csv = '﻿' + headers.join(',') + '\n';
    rows.forEach(row => { csv += headers.map((_,i)=>'"'+String(row[i]||'').replace(/"/g,'""')+'"').join(',') + '\n'; });
    dlBlob(new Blob([csv],{type:'text/csv;charset=utf-8'}), name+'.csv');
  } else if(type==='xlsx'){
    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    const wb = XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb, ws, name.substring(0,31));
    XLSX.writeFile(wb, name+'.xlsx');
  } else if(type==='pdf'){
    const win = window.open('','_blank');
    const trs = rows.map(r => `<tr>${headers.map((_,i)=>`<td>${escHtml(String(r[i]||''))}</td>`).join('')}</tr>`).join('');
    win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:'Sarabun',sans-serif;font-size:11px;padding:20px}h2{font-size:16px;margin-bottom:4px}.sub{color:#666;font-size:11px;margin-bottom:14px}table{width:100%;border-collapse:collapse}th{background:#1a56db;color:#fff;padding:6px 8px;text-align:left;font-size:11px}td{padding:5px 8px;border-bottom:1px solid #eee;font-size:11px}tr:nth-child(even){background:#f8fafc}@media print{body{padding:0}}</style></head><body><h2>รายการพัสดุแผนกบริการเครื่องมือแพทย์</h2><div class="sub">ชีท: ${escHtml(name)} | จำนวน: ${rows.length} รายการ | วันที่: ${new Date().toLocaleDateString('th-TH')}</div><table><thead><tr>${headers.map(h=>`<th>${escHtml(h)}</th>`).join('')}</tr></thead><tbody>${trs}</tbody></table><script>window.onload=()=>window.print()<\/script></body></html>`);
    win.document.close();
  }
}
function dlBlob(blob, fn){ const u = URL.createObjectURL(blob), a = document.createElement('a'); a.href = u; a.download = fn; a.click(); setTimeout(()=>URL.revokeObjectURL(u), 1000); }

// =============================================
// REFRESH / UTIL
// =============================================
async function refreshData(){
  S.allItems = {}; S.dashStats = null;
  toast('รีเฟรชแล้ว','success');
  if(S.currentCat) await loadCategoryItems(S.currentCat);
  else await loadDashboard();
}
function showLoading(v){ document.getElementById('loading').style.display = v ? 'flex' : 'none'; }
function toast(msg, type=''){
  const el=document.createElement('div'); el.className='toast '+type;
  const ic = type==='success' ? 'check-circle' : type==='error' ? 'exclamation-circle' : 'info-circle';
  el.innerHTML = `<i class="fas fa-${ic}"></i> ${msg}`;
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(()=>el.remove(), 3500);
}
function esc(s){ return String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }
function escHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// =============================================
// CREATE CATEGORY (manual)
// =============================================
async function createCategoryPrompt(){
  const name = prompt('ชื่อประเภทพัสดุ (sheet ใหม่):');
  if(!name||!name.trim()) return;
  const cols = prompt('คอลัมน์ทั้งหมด คั่นด้วย | (เช่น: ลำดับ|รายการ|รุ่น|จำนวน|สถานะ|ใช้ที่แผนก)', 'ลำดับ|รายการ|รุ่น|S/N|จำนวน|หน่วยนับ|สถานะ|ใช้ที่แผนก');
  if(!cols||!cols.trim()) return;
  const headers = cols.split('|').map(s=>s.trim()).filter(Boolean);
  showLoading(true);
  try {
    const { error } = await sb.from('categories').insert({ name: name.trim(), headers, display_order: S.categories.length });
    if(error) throw error;
    toast('สร้าง "'+name+'" สำเร็จ','success');
    await init();
  } catch(e){ toast('สร้างไม่สำเร็จ: '+e.message,'error'); }
  finally { showLoading(false); }
}

// =============================================
// STATUS DRILL-DOWN MODAL
// =============================================
let smState={statusFilter:'',color:'#2563eb',smPage:1,smPS:50,smRows:[]};

async function ensureAllItemsLoaded(){
  const missing = S.categories.filter(c => !S.allItems[c.id]);
  if(!missing.length) return;
  await Promise.all(missing.map(async cat => {
    try {
      const { data } = await sb.from('items').select('*').eq('category_id', cat.id).order('row_index').order('id');
      S.allItems[cat.id] = data || [];
    } catch(e){ S.allItems[cat.id] = []; }
  }));
}

async function openStatusModal(statusLabel, color){
  smState.statusFilter = statusLabel;
  smState.color = color || '#2563eb';
  smState.smPage = 1;
  document.getElementById('sm-search-input').value = '';
  const badge = document.getElementById('sm-badge');
  badge.textContent = statusLabel;
  badge.style.background = color+'22';
  badge.style.color = color;
  document.getElementById('sm-title').textContent = 'รายการพัสดุสถานะ: '+statusLabel;
  document.getElementById('sm-count').textContent = '...';
  document.getElementById('sm-subtitle').textContent = 'กำลังโหลด...';
  document.getElementById('status-overlay').classList.add('show');
  await ensureAllItemsLoaded();
  collectSmRows(statusLabel);
  renderSmTable();
}

function collectSmRows(statusLabel){
  smState.smRows = [];
  S.categories.forEach(cat => {
    const items = S.allItems[cat.id] || [];
    const headers = cat.headers || [];
    const sk = headers.findIndex(isStatusCol);
    items.forEach(it => {
      let sv = sk >= 0 ? normalizeStatus(it.data?.[headers[sk]]) : '';
      if(!sv) sv = 'ไม่ระบุสถานะ';
      if(sv === statusLabel){
        smState.smRows.push({ item: it, sheetName: cat.name, headers, catId: cat.id });
      }
    });
  });
}

function renderSmTable(){
  const q = document.getElementById('sm-search-input').value.toLowerCase();
  let filtered = smState.smRows;
  if(q) filtered = filtered.filter(({item, headers}) => rowToArr(item, headers).some(v => String(v||'').toLowerCase().includes(q)));
  const total = filtered.length;
  const pages = Math.max(1, Math.ceil(total/smState.smPS));
  const start = (smState.smPage-1) * smState.smPS;
  const pageRows = filtered.slice(start, start+smState.smPS);

  document.getElementById('sm-count').textContent = total.toLocaleString()+' รายการ';
  if(smState.statusFilter !== '__ALL_SHEETS__' && smState.statusFilter !== '__MULTI__'){
    document.getElementById('sm-subtitle').textContent = 'พบใน '+new Set(filtered.map(r=>r.sheetName)).size+' ประเภท';
  } else {
    document.getElementById('sm-subtitle').textContent = 'รวม '+new Set(smState.smRows.map(r=>r.sheetName)).size+' ประเภท';
  }

  const baseHeaders = pageRows[0]?.headers || smState.smRows[0]?.headers || [];
  const skHead = baseHeaders.findIndex(isStatusCol);
  document.getElementById('sm-thead').innerHTML = `<tr>
    <th style="width:40px;position:sticky;top:0;background:#f8fafc;z-index:25;border-bottom:2px solid var(--border);padding:10px 12px;font-size:12px;font-weight:700;color:var(--text-muted)">#</th>
    <th style="position:sticky;top:0;background:#f8fafc;z-index:20;border-bottom:2px solid var(--border);padding:10px 14px;font-size:12px;font-weight:700;color:var(--text-muted);white-space:nowrap;min-width:100px">ประเภท/ชีท</th>
    ${baseHeaders.map((h,i)=>{
      const isStatus = i===skHead;
      return `<th style="position:sticky;top:0;background:${isStatus?'#f0fdf4':'#f8fafc'};z-index:20;border-bottom:2px solid ${isStatus?'#10b981':'var(--border)'};padding:10px 14px;font-size:12px;font-weight:700;color:${isStatus?'#059669':'var(--text-muted)'};white-space:nowrap;min-width:100px">${escHtml(h)}</th>`;
    }).join('')}
    <th style="position:sticky;top:0;background:#f8fafc;z-index:20;border-bottom:2px solid var(--border);padding:10px 14px;font-size:12px;font-weight:700;color:var(--text-muted);white-space:nowrap;width:60px">แก้ไข</th>
  </tr>`;

  if(!pageRows.length){
    document.getElementById('sm-tbody').innerHTML = `<tr><td colspan="999" style="text-align:center;padding:40px;color:var(--text-muted)"><i class="fas fa-inbox" style="font-size:32px;display:block;margin-bottom:10px;opacity:.35"></i>ไม่พบข้อมูล</td></tr>`;
  } else {
    document.getElementById('sm-tbody').innerHTML = pageRows.map(({item, sheetName, headers, catId}, ri)=>{
      const sk = headers.findIndex(isStatusCol);
      const cells = headers.map((h,ci)=>{
        let val = item.data?.[h] === undefined ? '' : String(item.data[h]);
        if(ci === sk){
          val = normalizeStatus(val);
          if(val) return `<td style="padding:9px 14px;white-space:nowrap"><span class="status-badge ${getStCls(val)}">${escHtml(val)}</span></td>`;
          return `<td style="padding:9px 14px;white-space:nowrap"><span style="color:var(--warning);font-size:11px;margin-right:6px">ไม่ระบุ</span></td>`;
        }
        return `<td style="padding:9px 14px;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(val)}">${escHtml(val)}</td>`;
      }).join('');
      return `<tr style="border-bottom:1px solid #f1f5f9">
        <td style="padding:9px 12px;color:var(--text-muted);font-size:11px;font-weight:600;white-space:nowrap">${start+ri+1}</td>
        <td style="padding:9px 14px;white-space:nowrap"><span class="sm-sheet-tag">${escHtml(sheetName)}</span></td>
        ${cells}
        <td style="padding:9px 10px;white-space:nowrap"><button class="btn btn-outline btn-sm btn-icon" onclick="smEdit(${catId},${item.id})" title="แก้ไขรายการนี้"><i class="fas fa-edit"></i></button></td>
      </tr>`;
    }).join('');
  }

  document.getElementById('sm-page-info').textContent = `หน้า ${smState.smPage}/${pages} (${total} รายการ)`;
  const btns = document.getElementById('sm-page-btns');
  let range = pages<=7 ? [...Array(pages)].map((_,i)=>i+1) :
              smState.smPage<=4 ? [1,2,3,4,5,'…',pages] :
              smState.smPage>=pages-3 ? [1,'…',pages-4,pages-3,pages-2,pages-1,pages] :
              [1,'…',smState.smPage-1,smState.smPage,smState.smPage+1,'…',pages];
  btns.innerHTML =
    `<div class="page-btn ${smState.smPage<=1?'dis':''}" onclick="smGoPage(${smState.smPage-1})"><i class="fas fa-chevron-left"></i></div>` +
    range.map(p=>p==='…'?`<div class="page-btn" style="cursor:default;border:none">…</div>`:`<div class="page-btn ${p===smState.smPage?'active':''}" onclick="smGoPage(${p})">${p}</div>`).join('') +
    `<div class="page-btn ${smState.smPage>=pages?'dis':''}" onclick="smGoPage(${smState.smPage+1})"><i class="fas fa-chevron-right"></i></div>`;
}

function smEdit(catId, itemId){
  const cat = S.categories.find(c => c.id === catId);
  if(!cat) return;
  S.currentCat = cat;
  const sf = smState.statusFilter, sc = smState.color;
  S._smReopen = ()=>{
    if(sf === '__NO_STATUS__') openNoStatusModal();
    else if(sf === '__ALL_SHEETS__') openSheetListModal();
    else openStatusModal(sf, sc);
  };
  openEditModal(itemId);
}

function smGoPage(p){
  const q = document.getElementById('sm-search-input').value.toLowerCase();
  const total = q ? smState.smRows.filter(({item, headers})=>rowToArr(item, headers).some(v=>String(v||'').toLowerCase().includes(q))).length : smState.smRows.length;
  const pages = Math.ceil(total/smState.smPS);
  if(p<1||p>pages) return;
  smState.smPage = p; renderSmTable();
  document.querySelector('#status-modal .sm-body').scrollTop = 0;
}

function closeStatusModal(){ document.getElementById('status-overlay').classList.remove('show'); }
document.getElementById('status-overlay').addEventListener('click', e => { if(e.target===document.getElementById('status-overlay')) closeStatusModal(); });

function exportSmCSV(){
  if(!smState.smRows.length) return;
  const baseHeaders = smState.smRows[0].headers;
  const headers = ['ประเภท/ชีท', ...baseHeaders];
  let csv = '﻿' + headers.join(',') + '\n';
  smState.smRows.forEach(({item, sheetName, headers: hdrs}) => {
    const arr = rowToArr(item, hdrs);
    csv += [sheetName, ...arr].map(v => '"'+String(v||'').replace(/"/g,'""')+'"').join(',') + '\n';
  });
  dlBlob(new Blob([csv],{type:'text/csv;charset=utf-8'}), (smState.statusFilter==='__ALL_SHEETS__'?'all':smState.statusFilter)+'.csv');
}

async function openSheetListModal(){
  smState.statusFilter='__ALL_SHEETS__'; smState.color='#2563eb'; smState.smPage=1;
  document.getElementById('sm-search-input').value='';
  document.getElementById('sm-title').textContent='รายการพัสดุทุกประเภท';
  const badge=document.getElementById('sm-badge'); badge.textContent='ทุกประเภท'; badge.style.background='#eff6ff'; badge.style.color='#2563eb';
  document.getElementById('sm-count').textContent = '...';
  document.getElementById('sm-subtitle').textContent = 'กำลังโหลด...';
  document.getElementById('status-overlay').classList.add('show');
  await ensureAllItemsLoaded();
  smState.smRows = [];
  S.categories.forEach(cat => { (S.allItems[cat.id]||[]).forEach(it => smState.smRows.push({ item: it, sheetName: cat.name, headers: cat.headers||[], catId: cat.id })); });
  renderSmTable();
}
async function openAllItemsModal(){ await openSheetListModal(); }

async function openMultiStatusModal(statusList, label, color){
  smState.statusFilter='__MULTI__'; smState.color=color||'#6366f1'; smState.smPage=1;
  document.getElementById('sm-search-input').value='';
  document.getElementById('sm-title').textContent='รายการพัสดุ: '+label;
  const badge=document.getElementById('sm-badge'); badge.textContent=label; badge.style.background=color+'22'; badge.style.color=color;
  document.getElementById('sm-count').textContent='...';
  document.getElementById('status-overlay').classList.add('show');
  await ensureAllItemsLoaded();
  smState.smRows=[];
  S.categories.forEach(cat=>{
    const items = S.allItems[cat.id]||[];
    const headers = cat.headers||[];
    const sk = headers.findIndex(isStatusCol);
    items.forEach(it=>{
      const sv = sk>=0 ? normalizeStatus(it.data?.[headers[sk]]) : '';
      if(statusList.includes(sv)) smState.smRows.push({ item: it, sheetName: cat.name, headers, catId: cat.id });
    });
  });
  renderSmTable();
}

async function openNoStatusModal(){
  smState.statusFilter='__NO_STATUS__'; smState.color='#f59e0b'; smState.smPage=1;
  document.getElementById('sm-search-input').value='';
  document.getElementById('sm-title').textContent='รายการที่ยังไม่ระบุสถานะ';
  const badge=document.getElementById('sm-badge'); badge.textContent='ไม่ระบุสถานะ'; badge.style.background='#fef3c7'; badge.style.color='#d97706';
  document.getElementById('sm-count').textContent='...'; document.getElementById('sm-subtitle').textContent='กำลังโหลด...';
  document.getElementById('status-overlay').classList.add('show');
  await ensureAllItemsLoaded();
  smState.smRows=[];
  S.categories.forEach(cat=>{
    const items=S.allItems[cat.id]||[]; const headers=cat.headers||[];
    const sk=headers.findIndex(isStatusCol); if(sk<0) return;
    items.forEach(it=>{ const sv=normalizeStatus(it.data?.[headers[sk]]); if(!sv||sv==='ไม่ระบุสถานะ') smState.smRows.push({item:it, sheetName:cat.name, headers, catId:cat.id}); });
  });
  renderSmTable();
}

// =============================================
// SEARCH MODE
// =============================================
function setSearchMode(mode){
  S.searchMode = mode;
  document.querySelectorAll('.search-mode-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+mode).classList.add('active');
  applyFilters();
}
function matchSearch(cellVal, q){
  if(!q) return true;
  switch(S.searchMode){
    case 'startswith': return cellVal.startsWith(q);
    case 'exact':      return cellVal===q;
    default:           return cellVal.includes(q);
  }
}
function highlightMatch(val, q, mode){
  if(!q||!val) return escHtml(val);
  const lv=val.toLowerCase(), lq=q.toLowerCase();
  let idx=-1;
  switch(mode){
    case 'startswith': idx=lv.startsWith(lq)?0:-1; break;
    case 'exact':      idx=lv===lq?0:-1; break;
    default:           idx=lv.indexOf(lq);
  }
  if(idx<0) return escHtml(val);
  return `${escHtml(val.substring(0,idx))}<mark class="search-highlight">${escHtml(val.substring(idx,idx+q.length))}</mark>${escHtml(val.substring(idx+q.length))}`;
}
function clearSearch(){ document.getElementById('search-input').value=''; document.getElementById('btn-clear-search').style.display='none'; applyFilters(); }
