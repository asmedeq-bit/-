async function showDashboard(){
  document.getElementById('view-dashboard').style.display='';
  document.getElementById('view-table').style.display='none';
  document.getElementById('btn-add').style.display='none';
  document.getElementById('page-title').textContent='Dashboard';
  document.getElementById('page-subtitle').textContent='ภาพรวมรายการพัสดุทั้งหมด';
  S.currentCat=null; setActiveNav('nav-dashboard');
  if(!S.dashStats) await loadDashboard();
}

async function loadDashboard(){
  showLoading(true);
  try {
    const [{ data: ds }, { data: ss }] = await Promise.all([
      sb.from('v_dashboard_stats').select('*'),
      sb.from('v_status_summary').select('*')
    ]);
    const sheetStats = (ds||[]).map(r => ({ id:r.category_id, name:r.category_name, count: Number(r.total_count)||0 }));
    const statusSummary = {}; let noStatusCount = 0;
    (ss||[]).forEach(r => {
      if(r.status === 'ไม่ระบุสถานะ') noStatusCount += Number(r.cnt)||0;
      else statusSummary[r.status] = Number(r.cnt)||0;
    });
    const totalItems = sheetStats.reduce((s,x)=>s+x.count,0);
    const stats = {
      totalSheets: sheetStats.filter(s=>s.count>0).length,
      totalItems, sheetStats, statusSummary, noStatusCount,
      _grandTotal: totalItems
    };
    S.dashStats = stats;
    renderDashboard(stats);
    showLoading(false);
  } catch(e){
    showLoading(false);
    toast('โหลด Dashboard ไม่สำเร็จ: '+e.message,'error');
  }
}

